{
	"image": "mcr.microsoft.com/devcontainers/universal:linux",
	"features": {
		"ghcr.io/devcontainers/features/desktop-lite:1": {
			"password": "vscode",
			"webPort": "6080",
			"vncPort": "5901"
		}
	},
	"forwardPorts": [
		6080
	],
	"portsAttributes": {
		"6080": {
			"label": "desktop",
			"onAutoForward": "openBrowser"
		}
	},
	"customizations": {
		"vscode": {
			"settings": {
				"extensions.disabled": [
					"GitHub.copilot",
					"GitHub.copilot-chat"
				]
			}
		}
	}
}